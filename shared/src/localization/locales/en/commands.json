{
  "play": {
    "name": "play",
    "description": "Play music from various sources",
    "options": {
      "query": "Search query or URL",
      "playlist": "Playlist name or URL",
      "file": "Local audio file"
    },
    "responses": {
      "success": "Now playing: {{track}}",
      "queued": "Added to queue: {{track}}",
      "notFound": "No results found for: {{query}}",
      "error": "Failed to play track"
    }
  },
  "pause": {
    "name": "pause",
    "description": "Pause current playback",
    "responses": {
      "success": "Playback paused",
      "notPlaying": "Nothing is currently playing",
      "error": "Failed to pause playback"
    }
  },
  "resume": {
    "name": "resume",
    "description": "Resume paused playback",
    "responses": {
      "success": "Playback resumed",
      "notPaused": "Playback is not paused",
      "error": "Failed to resume playback"
    }
  },
  "stop": {
    "name": "stop",
    "description": "Stop playback and clear queue",
    "responses": {
      "success": "Playback stopped and queue cleared",
      "notPlaying": "Nothing is currently playing",
      "error": "Failed to stop playback"
    }
  },
  "next": {
    "name": "next",
    "description": "Skip to next track",
    "responses": {
      "success": "Skipped to next track",
      "noNext": "No next track in queue",
      "error": "Failed to skip track"
    }
  },
  "skip": {
    "name": "skip",
    "description": "Skip current track",
    "responses": {
      "success": "Track skipped",
      "error": "Failed to skip track"
    }
  },
  "previous": {
    "name": "previous",
    "description": "Go back to previous track",
    "responses": {
      "success": "Playing previous track",
      "noPrevious": "No previous track available",
      "error": "Failed to go to previous track"
    }
  },
  "queue": {
    "name": "queue",
    "description": "Show current playback queue",
    "options": {
      "page": "Page number to display"
    },
    "responses": {
      "empty": "Queue is empty",
      "showing": "Showing queue ({{current}}/{{total}})"
    }
  },
  "clear": {
    "name": "clear",
    "description": "Clear the playback queue",
    "responses": {
      "success": "Queue cleared",
      "empty": "Queue is already empty",
      "error": "Failed to clear queue"
    }
  },
  "shuffle": {
    "name": "shuffle",
    "description": "Shuffle the current queue",
    "responses": {
      "success": "Queue shuffled",
      "empty": "Cannot shuffle empty queue",
      "error": "Failed to shuffle queue"
    }
  },
  "volume": {
    "name": "volume",
    "description": "Set playback volume",
    "options": {
      "level": "Volume level (0-100)"
    },
    "responses": {
      "success": "Volume set to {{level}}%",
      "invalid": "Volume must be between 0 and 100",
      "error": "Failed to set volume"
    }
  },
  "seek": {
    "name": "seek",
    "description": "Seek to specific position in track",
    "options": {
      "position": "Position in seconds or MM:SS format"
    },
    "responses": {
      "success": "Seeked to {{position}}",
      "invalid": "Invalid position format",
      "error": "Failed to seek"
    }
  },
  "nowplaying": {
    "name": "nowplaying",
    "description": "Show currently playing track information",
    "responses": {
      "nothing": "Nothing is currently playing",
      "info": "Now playing: {{track}} by {{artist}}"
    }
  },
  "join": {
    "name": "join",
    "description": "Join a voice channel",
    "options": {
      "channel": "Voice channel to join"
    },
    "responses": {
      "success": "Joined {{channel}}",
      "alreadyConnected": "Already connected to {{channel}}",
      "noPermission": "No permission to join {{channel}}",
      "channelFull": "Voice channel is full",
      "error": "Failed to join voice channel"
    }
  },
  "leave": {
    "name": "leave",
    "description": "Leave current voice channel",
    "responses": {
      "success": "Left voice channel",
      "notConnected": "Not connected to any voice channel",
      "error": "Failed to leave voice channel"
    }
  },
  "setActive": {
    "name": "set-active",
    "description": "Set the active bot instance",
    "options": {
      "instance": "Bot instance ID",
      "guild": "Guild ID (defaults to current guild)"
    },
    "responses": {
      "success": "Set {{instance}} as active bot",
      "notFound": "Bot instance {{instance}} not found",
      "alreadyActive": "{{instance}} is already the active bot",
      "error": "Failed to set active bot. Currently active: {{instance}}"
    }
  },
  "ping": {
    "name": "ping",
    "description": "Check bot connectivity",
    "responses": {
      "success": "Pong! Latency: {{latency}}ms",
      "error": "Failed to ping bot"
    }
  },
  "help": {
    "name": "help",
    "description": "Show help information",
    "options": {
      "command": "Specific command to get help for"
    },
    "responses": {
      "general": "Available commands:",
      "specific": "Help for command: {{command}}"
    }
  },
  "save": {
    "name": "save",
    "description": "Save current track or playlist"
  },
  "remove": {
    "name": "remove",
    "description": "Remove track from queue"
  },
  "playnext": {
    "name": "playnext",
    "description": "Add track to play next in queue"
  },
  "meme": {
    "name": "meme",
    "description": "Get a random meme"
  },
  "loop": {
    "name": "loop",
    "description": "Toggle loop mode",
    "responses": {
      "success": "Repeat mode updated",
      "error": "Failed to update repeat mode"
    }
  },
  "jump": {
    "name": "jump",
    "description": "Jump to specific track in queue"
  },
  "hello": {
    "name": "hello",
    "description": "Say hello to the bot"
  },
  "ask": {
    "name": "ask",
    "description": "Ask the bot a question"
  },
  "status": {
    "name": "status",
    "description": "Show bot status information",
    "responses": {
      "info": "Bot Status:\nUptime: {{uptime}}\nGuilds: {{guilds}}\nUsers: {{users}}"
    }
  },
  "categories": {
    "music": "Music",
    "moderation": "Moderation",
    "utility": "Utility",
    "fun": "Fun",
    "admin": "Administration"
  },
  "validation": {
    "required": "This parameter is required",
    "invalidType": "Invalid parameter type",
    "outOfRange": "Parameter value out of range",
    "invalidChoice": "Invalid choice for parameter"
  },
  "shutdown": {
    "name": "shutdown",
    "description": "Shut down a bot instance",
    "options": {
      "instance": "Bot instance ID"
    },
    "responses": {
      "self": "Shutting down instance {{instance}}...",
      "mismatch": "Requested instance {{requested}} does not match this bot ({{current}})."
    }
  }
}
