{
  "name": "discord-dashboard-shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./localization": {
      "import": "./dist/localization/index.js",
      "types": "./dist/localization/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "oxlint --deny-warnings src",
    "lint:fix": "oxlint --deny-warnings --fix src",
    "type-check": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest --coverage --passWithNoTests"
  },
  "dependencies": {
    "i18next": "^26.3.6",
    "i18next-fs-backend": "^2.6.6",
    "i18next-http-backend": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
