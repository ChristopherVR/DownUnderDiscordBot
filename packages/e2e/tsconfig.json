{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["playwright/**/*.ts", "harness/**/*.ts", "fixtures/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "test-results", "playwright-report", "blob-report", ".playwright"]
}
