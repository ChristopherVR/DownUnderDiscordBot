# Discord Bot Configuration
CLIENT_TOKEN=your-discord-bot-token
GUILD_ID=your-guild-id

# Server Configuration
PORT=3000
HOST=localhost

# Music Configuration
MUSIC_FOLDER_PATH=D:\Music
MUSIC_CHANNEL_ID=your-music-channel-id
FFMPEG_PATH=ffmpeg

# State Management
STATE_CHANNEL_ID=your-state-channel-id
STATE_BACKEND=channel

# Database
DATABASE_URL=file:./data/bot.db

# Optional: Spotify API (for Spotify search/metadata)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: OpenAI (for /ask command)
OPEN_AI_TOKEN=

# Docker
DOCKER_REGISTRY=127.0.0.1
TAG=latest
ENVIRONMENT=development
