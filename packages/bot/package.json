{
  "name": "discord-bot",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@discord-player/extractor": "^7.1.0",
    "@discordjs/voice": "^0.19.0",
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "discord-dashboard-shared": "workspace:*",
    "discord-player": "^7.1.0",
    "discord-voip": "^7.1.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "i18next": "^25.8.13",
    "i18next-http-backend": "^3.0.2",
    "jsonwebtoken": "^9.0.3",
    "mediaplex": "^1.0.0",
    "multer": "^2.1.0",
    "music-metadata": "^11.12.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "soundcloud.ts": "^0.7.2",
    "spotify-web-api-node": "^5.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "youtubei.js": "^16.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.2",
    "@types/spotify-web-api-node": "^5.0.11",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
