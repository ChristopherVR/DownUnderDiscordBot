{
  "name": "discord-bot",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-locales.mjs",
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "lint": "oxlint --deny-warnings src",
    "lint:fix": "oxlint --deny-warnings --fix src",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@discordjs/voice": "^0.19.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "discord-dashboard-shared": "workspace:*",
    "discord-player": "^7.2.0",
    "discord-voip": "^7.2.0",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "i18next": "^26.3.6",
    "i18next-http-backend": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "mediaplex": "^1.0.0",
    "multer": "^2.2.0",
    "music-metadata": "^11.14.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "soundcloud.ts": "^0.7.4",
    "spotify-web-api-node": "^5.0.2",
    "uuid": "^14.0.1",
    "ws": "^8.21.1",
    "youtubei.js": "^17.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/spotify-web-api-node": "^5.0.11",
    "@types/supertest": "^7.2.1",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "ffmpeg-static": "^5.3.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
