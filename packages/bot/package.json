{
  "name": "discord-bot",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@discord-player/extractor": "^7.1.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "latest",
    "@distube/ytdl-core": "^4.16.12",
    "@distube/ytsr": "^2.0.4",
    "@prisma/client": "^6.4.0",
    "axios": "latest",
    "cors": "latest",
    "discord-dashboard-shared": "workspace:*",
    "discord-player": "latest",
    "discord-player-youtubei": "^1.5.0",
    "discord.js": "latest",
    "dotenv": "latest",
    "express": "latest",
    "i18next": "latest",
    "i18next-http-backend": "latest",
    "multer": "latest",
    "music-metadata": "^9.0.0",
    "pino": "latest",
    "pino-http": "latest",
    "soundcloud.ts": "^0.5.5",
    "spotify-web-api-node": "^5.0.2",
    "uuid": "latest",
    "ws": "latest",
    "youtubei.js": "^15.1.1"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/multer": "latest",
    "@types/node": "latest",
    "@types/supertest": "^6.0.2",
    "@types/ws": "latest",
    "pino-pretty": "latest",
    "prisma": "^6.4.0",
    "supertest": "^7.1.4",
    "ts-node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
