{
  "name": "down-under-discord-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:shared && pnpm run build:bot",
    "build:shared": "pnpm --filter discord-dashboard-shared build",
    "build:bot": "pnpm --filter discord-bot build",
    "build:desktop": "pnpm --filter discord-bot-desktop build",
    "build:all": "pnpm run build:shared && pnpm run build:bot && pnpm run build:desktop",
    "dev": "pnpm run dev:shared & pnpm run dev:bot",
    "dev:shared": "pnpm --filter discord-dashboard-shared dev",
    "dev:bot": "pnpm --filter discord-bot dev",
    "dev:desktop": "pnpm --filter discord-bot-desktop dev",
    "start": "NODE_ENV=production pnpm --filter discord-bot start",
    "start:prod": "NODE_ENV=production pm2 start --interpreter tsx packages/bot/src/index.ts --name discord-bot",
    "test": "pnpm run test:shared && pnpm run test:bot && pnpm run test:desktop",
    "test:shared": "pnpm --filter discord-dashboard-shared test",
    "test:bot": "pnpm --filter discord-bot test",
    "test:desktop": "pnpm --filter discord-bot-desktop test",
    "test:e2e": "pnpm --filter discord-bot-e2e test",
    "test:coverage": "pnpm run test:shared -- --coverage && pnpm run test:bot -- --coverage",
    "lint": "pnpm run lint:bot && pnpm run lint:shared",
    "lint:bot": "pnpm --filter discord-bot lint",
    "lint:shared": "pnpm --filter discord-dashboard-shared lint",
    "lint:fix": "pnpm run lint:bot -- --fix && pnpm run lint:shared -- --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter discord-bot db:generate",
    "db:push": "pnpm --filter discord-bot db:push",
    "db:migrate": "pnpm --filter discord-bot db:migrate",
    "db:studio": "pnpm --filter discord-bot db:studio",
    "clean": "rm -rf packages/bot/dist packages/shared/dist packages/desktop/dist",
    "clean:windows": "if exist packages\\bot\\dist rmdir /s /q packages\\bot\\dist && if exist packages\\shared\\dist rmdir /s /q packages\\shared\\dist",
    "health-check": "curl -f http://localhost:3001/health || exit 1",
    "precommit": "pnpm run lint && pnpm run format:check && pnpm run test",
    "postinstall": "pnpm run build:shared",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --deny-warnings",
      "oxfmt --check"
    ],
    "*.{js,jsx,json,md}": [
      "oxfmt --check"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "mediaplex"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "@tailwindcss/vite>vite": "8"
      }
    }
  }
}
